DATABASE_URL="postgresql://postgres:postgres@localhost:5432/myfamilyexpenses?schema=public"
SESSION_COOKIE_NAME="mfe_session"
SESSION_SECRET="replace-with-a-long-random-secret"
SESSION_TTL_DAYS="7"
UPLOAD_DIR="./uploads"
MAX_UPLOAD_MB="10"
OCR_PROVIDER="tesseract"
TESSERACT_CACHE_DIR=".cache/tesseract"
TESSERACT_LANG_PATH=""
OCR_DEBUG="false"
OCR_DEBUG_DIR=".cache/ocr-debug"
SEED_USER_PASSWORD="set-this-locally-before-seeding"
